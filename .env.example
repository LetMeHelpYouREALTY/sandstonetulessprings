# Canonical production origin — must match your Google Search Console property (www vs apex).
NEXT_PUBLIC_BASE_URL=https://www.sandstonetulessprings.com

# Optional ISO date for sitemap lastmod (e.g. 2026-05-19) — set in Vercel on production deploys.
# NEXT_PUBLIC_BUILD_DATE=2026-05-19

# Public contact email — must match GBP when email is listed on the profile.
# NEXT_PUBLIC_SITE_EMAIL=drjansells@sandstonetulessprings.com

# Calendly — secondary conversion (Follow Up Boss via native integration + UTM)
# 30-min private tour (primary page CTAs):
# NEXT_PUBLIC_CALENDLY_TOUR_URL=https://calendly.com/your-event/tour
# 15-min conversation (floating badge):
# NEXT_PUBLIC_CALENDLY_CONSULTATION_URL=https://calendly.com/your-event/consultation
# Optional fallback if only one event type is configured:
# NEXT_PUBLIC_CALENDLY_URL=
